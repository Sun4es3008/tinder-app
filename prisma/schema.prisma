datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String @id @default(cuid())
  name     String
  bio      String
  photoUrl String
  age      Int
  gender   String
}

model Match {
  id            String   @id @default(cuid())
  userId        String
  matchedUserId String
  createdAt     DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  matchId   String
  text      String
  senderId  String
  createdAt DateTime @default(now())
}
